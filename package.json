{
  "name": "afnm-my-mod",
  "version": "0.1.0",
  "description": "Starter AFNM mod scaffold with runtime validation and workshop packaging helpers.",
  "author": {
    "name": "your-name"
  },
  "gameVersion": "0.6.50",
  "packageManager": "bun@1.3.11",
  "afnmWorkshop": {
    "workshopId": "",
    "title": "My AFNM Mod",
    "description": "Describe what your mod changes, who it is for, and any important compatibility notes.",
    "tags": [
      "Gameplay"
    ],
    "visibility": "private",
    "previewImagePath": ""
  },
  "main": "mod.js",
  "scripts": {
    "prebuild": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build": "webpack --mode production",
    "postbuild": "node scripts/zip-dist.js",
    "workshop:upload": "bun run scripts/workshop-upload.ts",
    "runtime:oracle": "node scripts/installed-game-runtime.js summary",
    "runtime:extract": "node scripts/installed-game-runtime.js extract",
    "runtime:grep": "node scripts/installed-game-runtime.js grep"
  },
  "devDependencies": {
    "afnm-types": "0.6.50",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "zip-a-folder": "^4.0.4"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
